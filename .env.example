# Copie para .env e ajuste conforme necessário
# cp .env.example .env

# Ollama — deixe em branco para usar o fallback (glossas concatenadas)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=tradutor-sc

# CORS — origens permitidas para o WebSocket (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:5173

# Confiança mínima para aceitar uma predição (0.0–1.0)
THRESHOLD=0.85
